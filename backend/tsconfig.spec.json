{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node16",
    "target": "ES2023",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "./",
    "paths": {}
  },
  "include": ["src/**/*.ts"]
}
