// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  BENEVOLE
}

enum TransponderStatus {
  EN_ATTENTE
  ATTRIBUE
  PERDU
  RECUPERE
}

enum ConversationType {
  PRIVATE
  GROUP
}

enum MessageType {
  TEXT
  IMAGE
}

enum ParticipantRole {
  ADMIN
  MEMBER
}

enum LogType { // a enrichier au fur et à mesure
  ADD_USER
  DELETE_USER
  ADD_TRANSPONDER
  DELETE_TRANSPONDER
  GIVE_TRANSPONDER
  LOOSE_TRANSPONDER
  RETURN_TRANSPONDER
}

enum NotificationType {
  INFO
  ALERT
  EMERGENCY
}

enum NotificationState {
  SEEN
  UNSEEN
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  lastName  String
  firstName String
  phone     String?
  password  String
  role      Role     @default(BENEVOLE)

  logs                     Log[]
  notifications            Notification[]
  transactions             TransponderTransaction[]
  createdConversations     Conversation[]
  messages                 Message[]
  conversationParticipants ConversationParticipant[]
}

model Edition {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(false)
  startDate DateTime
  endDate   DateTime

  courses      Course[]
  transponders Transponder[]
}

model Course {
  id           Int      @id @default(autoincrement())
  name         String
  distanceTour Float
  dateAndTime  DateTime
  editionId    Int

  edition Edition @relation(fields: [editionId], references: [id], onDelete: Cascade)
  teams   Team[]
}

model Team {
  id             Int     @id @default(autoincrement())
  num            Int
  name           String  @unique
  nbTour         Int     @default(0)
  courseId       Int
  respRunnerId   Int?    @unique
  /** Coureur à qui le transpondeur actif a été attribué (affichage « Resp transpondeur »). */
  transponderHolderRunnerId Int? @unique
  /** Course terminée (transpondeur récupéré) — plus d'attribution possible. */
  courseFinished Boolean @default(false)

  course       Course        @relation(fields: [courseId], references: [id])
  runners      Runner[]      @relation("TeamRunners")
  respRunner   Runner?       @relation("TeamResponsible", fields: [respRunnerId], references: [id])
  transponderHolderRunner   Runner?       @relation("TeamTransponderHolder", fields: [transponderHolderRunnerId], references: [id], onDelete: SetNull)
  transponders            Transponder[]
  transponderTransactions TransponderTransaction[]
}

model Runner {
  id        Int     @id @default(autoincrement())
  teamId    Int
  lastName  String
  firstName String
  email     String? @unique
  phone     String?

  team Team @relation("TeamRunners", fields: [teamId], references: [id], onDelete: Cascade)

  responsibleForTeam Team? @relation("TeamResponsible")
  transponderHolderForTeam Team? @relation("TeamTransponderHolder")
}

model Transponder {
  id        Int               @id @default(autoincrement())
  status    TransponderStatus @default(EN_ATTENTE)
  teamId    Int?
  editionId Int

  team    Team?    @relation(fields: [teamId], references: [id])
  edition Edition  @relation(fields: [editionId], references: [id], onDelete: Cascade)

  transactions TransponderTransaction[]
}

model TransponderTransaction {
  id            Int               @id @default(autoincrement())
  transponderId Int
  teamId        Int?
  userId        Int
  dateTime      DateTime          @default(now())
  type          TransponderStatus

  transponder Transponder @relation(fields: [transponderId], references: [id])
  team        Team?       @relation(fields: [teamId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}

model Log {
  id       Int      @id @default(autoincrement())
  dateTime DateTime @default(now())
  message  String
  type     LogType
  userId   Int

  user User @relation(fields: [userId], references: [id])
}

model Notification {
  id      Int      @id @default(autoincrement())
  type NotificationType @default(INFO)
  userId  Int
  message String
  date    DateTime @default(now())
  state   NotificationState @default(UNSEEN)

  user User @relation(fields: [userId], references: [id])
}

model Conversation {
  id            Int              @id @default(autoincrement())
  name          String?
  type          ConversationType
  createdByUserId Int
  lastMessageAt DateTime?

  createdByUser User                      @relation(fields: [createdByUserId], references: [id])
  messages      Message[]
  participants  ConversationParticipant[]
}

model Message {
  id             Int         @id @default(autoincrement())
  conversationId Int
  senderUserId   Int
  content        String
  messageType    MessageType @default(TEXT)
  createdAt      DateTime    @default(now())
  editedAt       DateTime?
  replyToMessageId Int?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderUserId], references: [id])
  replyToMessage Message?     @relation("Replies", fields: [replyToMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies        Message[]    @relation("Replies")
}

model ConversationParticipant {
  id               Int             @id @default(autoincrement())
  userId           Int
  conversationId   Int
  role             ParticipantRole @default(MEMBER)
  joinedAt         DateTime        @default(now())
  leftAt           DateTime?
  lastReadMessageId Int?

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
}